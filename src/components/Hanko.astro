---
interface Props {
  text?: string;
  size?: number;
  className?: string;
  style?: string;
  delay?: number;
}
const {
  text = "忍",
  size = 110,
  className = "",
  style = "",
  delay = 900,
} = Astro.props;
const inner = size - 14;
---

<div
  class={className}
  style={`width:${size}px; height:${size}px; position:relative; opacity:0; animation: hanko-stamp 0.65s cubic-bezier(0.2, 0.6, 0.2, 1) ${delay}ms forwards; ${style}`}
  aria-hidden="true"
>
  <svg viewBox="0 0 120 120" width={size} height={size} style="filter: drop-shadow(0 2px 0 rgba(20,17,13,0.15));">
    <!-- weathered outer square frame -->
    <rect
      x="7" y="7" width="106" height="106"
      fill="none"
      stroke="#b83227"
      stroke-width="5"
      stroke-linejoin="miter"
    />
    <!-- inner crop marks / cracks -->
    <path d="M10 30 L10 10 L30 10" stroke="#b83227" stroke-width="2" fill="none" opacity="0.55"/>
    <path d="M90 10 L110 10 L110 30" stroke="#b83227" stroke-width="2" fill="none" opacity="0.55"/>
    <path d="M110 90 L110 110 L90 110" stroke="#b83227" stroke-width="2" fill="none" opacity="0.55"/>
    <path d="M30 110 L10 110 L10 90" stroke="#b83227" stroke-width="2" fill="none" opacity="0.55"/>
    <!-- character -->
    <text
      x="60" y="82"
      text-anchor="middle"
      font-family="Shippori Mincho, serif"
      font-size="72"
      font-weight="700"
      fill="#b83227"
    >{text}</text>
    <!-- texture specks simulating ink fade -->
    <circle cx="22" cy="24" r="2" fill="#f3e9cf" opacity="0.7"/>
    <circle cx="96" cy="36" r="1.5" fill="#f3e9cf" opacity="0.6"/>
    <circle cx="30" cy="90" r="1.2" fill="#f3e9cf" opacity="0.7"/>
    <circle cx="84" cy="100" r="2.2" fill="#f3e9cf" opacity="0.65"/>
  </svg>
</div>
