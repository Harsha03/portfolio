---
// Chidori — "One Thousand Birds" / Lightning Blade.
// Chaotic electric orb. Jagged lightning bolts radiating outward, each
// flickering at its own staggered rhythm. Bright white-blue, no spiral —
// this is sharp, crackling energy, not a smooth Rasengan sphere.
//
// 24 bolts at evenly-spaced angles, each a jagged polyline.
// Central nucleus pulses/crackles. Outer halo breathes.

const boltCount = 24;

// Jagged lightning path (normalized 0..1 from center outward).
// y zig-zags so each bolt reads as electric.
const boltPath = (seed: number) => {
  // Pseudo-random jitter from the seed for variation.
  const rnd = (n: number) => {
    const x = Math.sin(seed * 12.9898 + n * 78.233) * 43758.5453;
    return x - Math.floor(x);
  };
  const steps = 5;
  let d = "M 0 0";
  for (let i = 1; i <= steps; i++) {
    const r = (i / steps) * 42; // outward radius 0..42 in SVG units
    const j = (rnd(i) - 0.5) * 7; // perpendicular jitter
    d += ` L ${r.toFixed(2)} ${j.toFixed(2)}`;
  }
  return d;
};

const bolts = Array.from({ length: boltCount }).map((_, i) => ({
  angle: (i * 360) / boltCount,
  delay: (i * 0.137) % 1.4, // staggered flicker starts
  duration: 1.2 + (i % 5) * 0.18,
  path: boltPath(i + 1),
  width: 1 + (i % 3) * 0.5,
}));

// A handful of longer arcs for dramatic cross-bolts
const crossBolts = [
  { angle: 25,  length: 58, delay: 0.2, width: 1.4 },
  { angle: 117, length: 62, delay: 0.7, width: 1.6 },
  { angle: 203, length: 55, delay: 1.1, width: 1.3 },
  { angle: 298, length: 64, delay: 0.4, width: 1.5 },
];
---

<div
  aria-hidden="true"
  class="pointer-events-none fixed bottom-[18%] left-6 z-40 hidden h-[104px] w-[104px] md:block"
>
  <!-- outer chaotic halo -->
  <span
    class="absolute inset-[-18px] rounded-full"
    style="background: radial-gradient(circle, rgba(255,255,255,0.45) 0%, rgba(126,207,255,0.3) 30%, transparent 65%); filter: blur(10px); animation: chidori-halo 1.1s steps(6, end) infinite;"
  ></span>

  <!-- lightning bolts -->
  <svg viewBox="-60 -60 120 120" width="104" height="104" class="absolute inset-0" style="filter: drop-shadow(0 0 3px #ffffff);">
    <defs>
      <linearGradient id="chidori-bolt" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%"  stop-color="#ffffff" stop-opacity="1" />
        <stop offset="55%" stop-color="#d4efff" stop-opacity="0.95" />
        <stop offset="100%" stop-color="#7ecfff" stop-opacity="0.3" />
      </linearGradient>
      <filter id="chidori-glow" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="1" result="b"/>
        <feMerge>
          <feMergeNode in="b" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- radial bolts -->
    <g filter="url(#chidori-glow)">
      {bolts.map((b) => (
        <g
          style={`transform: rotate(${b.angle}deg); transform-origin: 0 0; animation: chidori-bolt-flicker ${b.duration}s steps(20, jump-none) ${b.delay}s infinite;`}
        >
          <path
            d={b.path}
            stroke="url(#chidori-bolt)"
            stroke-width={b.width}
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </g>
      ))}
    </g>

    <!-- longer cross bolts -->
    <g filter="url(#chidori-glow)">
      {crossBolts.map((c) => (
        <g
          style={`transform: rotate(${c.angle}deg); transform-origin: 0 0; animation: chidori-bolt-flicker ${1.4}s steps(18, jump-none) ${c.delay}s infinite;`}
        >
          <path
            d={`M 6 0 L 14 -${3 + (c.length % 4)} L ${c.length * 0.4} 2 L ${c.length * 0.7} -${2 + (c.length % 3)} L ${c.length} 0`}
            stroke="#ffffff"
            stroke-width={c.width}
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="miter"
            opacity="0.95"
          />
        </g>
      ))}
    </g>

    <!-- outer jagged ring: a jagged polygon that flickers -->
    <polygon
      points="36,0 30,6 24,-5 16,8 6,-4 -2,9 -12,-3 -20,7 -28,-5 -34,6 -36,0 -30,-8 -22,4 -14,-10 -5,4 4,-9 12,3 20,-8 28,5 34,-6"
      fill="none"
      stroke="#ffffff"
      stroke-width="1"
      opacity="0.6"
      style="animation: chidori-bolt-flicker 0.9s steps(14, jump-none) 0.05s infinite;"
    />
    <polygon
      points="36,0 30,6 24,-5 16,8 6,-4 -2,9 -12,-3 -20,7 -28,-5 -34,6 -36,0 -30,-8 -22,4 -14,-10 -5,4 4,-9 12,3 20,-8 28,5 34,-6"
      fill="none"
      stroke="#7ecfff"
      stroke-width="0.6"
      opacity="0.5"
      transform="rotate(15)"
      style="animation: chidori-bolt-flicker 1.1s steps(14, jump-none) 0.45s infinite;"
    />
  </svg>

  <!-- nucleus -->
  <span
    class="absolute left-1/2 top-1/2 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white"
    style="animation: chidori-core-crackle 0.6s steps(6, end) infinite;"
  ></span>
  <span
    class="absolute left-1/2 top-1/2 h-1.5 w-1.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white"
    style="box-shadow: 0 0 8px #ffffff, 0 0 16px rgba(126,207,255,0.9);"
  ></span>

  <!-- label -->
  <span
    class="absolute -bottom-6 left-1/2 -translate-x-1/2 whitespace-nowrap font-mono text-[9px] uppercase tracking-[0.3em] text-[#7ecfff]/70"
  >
    千鳥 · Chidori
  </span>
</div>
