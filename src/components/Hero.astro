---
const tagline = "I build AI that thinks, plans, and executes — not just responds.";
const sub =
  "Agentic AI engineer shipping autonomous, tool-using systems end-to-end — iOS, Next.js, FastAPI, and everything between.";
---

<section id="top" class="relative overflow-hidden">
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -top-16 -right-8 select-none font-jp text-[18rem] leading-none text-konoha/7 md:text-[24rem]"
  >
    忍
  </span>
  <div class="mx-auto max-w-page px-6 pt-20 pb-24 md:pt-28 md:pb-32">
    <p class="text-xs uppercase tracking-[0.3em] text-konoha">Konoha · 木ノ葉</p>
    <h1 class="mt-4 font-serif text-5xl font-bold leading-[1.05] text-paper md:text-7xl">
      Harsha Jaiganesh
    </h1>
    <p class="mt-5 max-w-prose font-serif text-xl text-paper/95 italic md:text-2xl">{tagline}</p>
    <p class="mt-3 max-w-prose text-base text-tan md:text-lg">{sub}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="#missions"
        class="inline-block bg-konoha px-5 py-2.5 text-sm font-medium text-ink transition hover:brightness-110"
      >
        ▸ View Missions
      </a>
      <a
        href="/resume.pdf"
        class="inline-block border border-tan px-5 py-2.5 text-sm font-medium text-paper transition hover:border-konoha hover:text-konoha"
      >
        Download Scroll
      </a>
    </div>
  </div>
</section>
