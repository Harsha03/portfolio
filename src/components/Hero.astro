---
import Hanko from "./Hanko.astro";
const tagline = "I build AI that thinks, plans, and executes — not just responds.";
---

<section id="top" class="grain relative overflow-hidden bg-ink">
  <!-- huge faded mincho kanji behind -->
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -top-28 -right-12 z-0 select-none font-jp leading-none text-vermillion/18 md:-right-8"
    style="font-size: clamp(20rem, 34vw, 40rem); animation: kanji-pulse 9s ease-in-out infinite;"
  >
    忍
  </span>

  <!-- tategaki kanji column in left margin -->
  <span
    aria-hidden="true"
    class="tategaki pointer-events-none absolute left-6 top-1/2 z-10 hidden -translate-y-1/2 font-jp text-[13px] tracking-[0.4em] text-gold/80 lg:inline-block"
    style="animation: tategaki-draw 1.4s cubic-bezier(0.7,0,0.3,1) 0.8s both;"
  >
    忍者　の　道　・　木ノ葉
  </span>

  <div class="relative z-10 mx-auto grid max-w-page grid-cols-12 gap-x-6 px-6 pt-20 pb-28 md:pt-28 md:pb-40 lg:pl-24">
    <!-- eyebrow label -->
    <div class="col-span-12 mb-8 flex items-baseline justify-between gap-6 border-b border-paper/10 pb-4 font-mono text-[11px] uppercase tracking-[0.3em] text-paper/60">
      <span>No. 01 — Portfolio Edition</span>
      <span class="hidden md:inline">April · 2026</span>
      <span class="text-vermillion">Konoha · 木ノ葉</span>
    </div>

    <!-- massive display name -->
    <h1 class="col-span-12 font-display font-bold leading-[0.88] text-paper md:col-span-10" style="font-size: clamp(3.5rem, 10vw, 9rem); letter-spacing: -0.035em;">
      <span class="hero-line hero-line-1 block" style="font-variation-settings: 'SOFT' 100, 'WONK' 1;">Harsha</span>
      <span class="hero-line hero-line-2 block italic text-paper/95" style="font-weight: 500; font-variation-settings: 'SOFT' 100;">Jaiganesh</span>
      <span class="hero-line hero-line-3 mt-4 flex items-center gap-6 text-[0.18em] tracking-[0.35em] uppercase text-gold">
        <span class="h-px flex-none w-14 bg-gold/70"></span>
        Agentic · AI · Engineer
        <span class="h-px flex-1 bg-gold/30"></span>
      </span>
    </h1>

    <!-- hanko seal, offset, rotated -->
    <div class="col-span-12 mt-6 md:col-span-2 md:mt-3 md:self-start md:justify-self-end">
      <Hanko text="忍" size={130} delay={950} />
    </div>

    <!-- tagline + subs -->
    <div class="hero-line hero-line-4 col-span-12 mt-10 grid grid-cols-12 gap-6 md:mt-16">
      <p class="col-span-12 font-display italic text-paper md:col-span-7" style="font-size: clamp(1.5rem, 2.4vw, 2.1rem); line-height: 1.25; font-variation-settings: 'SOFT' 50;">
        {tagline}
      </p>
      <div class="col-span-12 md:col-span-5 md:pl-8 md:border-l md:border-paper/15">
        <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-gold/80">§ Summary</p>
        <p class="mt-3 text-paper/85">
          Production-grade LLM systems end-to-end — multi-agent orchestration, strict tool schemas,
          web-grounded verification, RAG over private corpora, multimodal extraction. Full-stack so AI
          features land as real products, not demos.
        </p>
      </div>
    </div>

    <!-- CTAs: editorial, understated -->
    <div class="hero-line hero-line-5 col-span-12 mt-12 flex flex-wrap items-center gap-x-10 gap-y-4 font-mono text-[12px] uppercase tracking-[0.25em]">
      <a href="#missions" class="btn-seal brush-link group flex items-center gap-3 text-paper">
        <svg class="shuriken h-3.5 w-3.5 text-vermillion" viewBox="0 0 40 40" fill="currentColor">
          <path d="M20 2 L23 17 L38 20 L23 23 L20 38 L17 23 L2 20 L17 17 Z" />
          <circle cx="20" cy="20" r="2.5" fill="#14110d" />
        </svg>
        Read the Missions
      </a>
      <a href="/resume.pdf" class="brush-link text-paper/80 hover:text-paper">
        Download the Scroll ↘
      </a>
      <a href="#hawk" class="brush-link text-paper/60 hover:text-paper">
        Send a Hawk
      </a>
    </div>
  </div>

  <!-- bottom hairline + footer row -->
  <div class="relative z-10 mx-auto max-w-page px-6 lg:pl-24">
    <div class="flex items-center justify-between border-t border-paper/10 py-4 font-mono text-[10px] uppercase tracking-[0.3em] text-paper/50">
      <span>↓ Scroll to read</span>
      <span class="text-gold/70">一 · 二 · 三 · 四 · 五 · 六 · 七</span>
    </div>
  </div>
</section>
