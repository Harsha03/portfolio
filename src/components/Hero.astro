---
import RunningNinja from "./RunningNinja.astro";
const tagline = "I build AI that thinks, plans, and executes — not just responds.";
const sub =
  "Agentic AI engineer shipping autonomous, tool-using systems end-to-end — iOS, Next.js, FastAPI, and everything between.";
---

<section id="top" class="relative overflow-hidden">
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -top-16 -right-8 select-none font-jp text-[18rem] leading-none text-konoha/10 md:text-[24rem]"
    style="animation: kanji-pulse 6s ease-in-out infinite;"
  >
    忍
  </span>
  <div class="relative mx-auto max-w-page px-6 pt-20 pb-24 md:pt-28 md:pb-32">
    <p class="text-xs uppercase tracking-[0.3em] text-konoha">Konoha · 木ノ葉</p>
    <h1 class="mt-4 font-serif text-5xl font-bold leading-[1.05] text-paper md:text-7xl">
      Harsha Jaiganesh
    </h1>
    <p class="mt-5 max-w-prose font-serif text-xl text-paper/95 italic md:text-2xl">{tagline}</p>
    <p class="mt-3 max-w-prose text-base text-tan md:text-lg">{sub}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="#missions"
        class="btn-konoha group inline-flex items-center gap-2 bg-konoha px-5 py-2.5 text-sm font-medium text-ink transition hover:brightness-110"
      >
        <svg class="shuriken h-3.5 w-3.5" viewBox="0 0 40 40" fill="currentColor">
          <path d="M20 2 L23 17 L38 20 L23 23 L20 38 L17 23 L2 20 L17 17 Z" />
          <circle cx="20" cy="20" r="2.5" fill="#0f0e0c" />
        </svg>
        View Missions
      </a>
      <a
        href="/resume.pdf"
        class="inline-block border border-tan px-5 py-2.5 text-sm font-medium text-paper transition hover:border-konoha hover:text-konoha"
      >
        Download Scroll
      </a>
    </div>
  </div>
  <RunningNinja />
</section>
