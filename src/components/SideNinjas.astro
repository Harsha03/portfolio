---
// Fixed-position ninja silhouettes in side margins on large screens.
// Hidden on mobile/tablet to preserve readability.
---

<div aria-hidden="true" class="pointer-events-none fixed inset-0 z-0 hidden xl:block">
  <!-- Left side: crouching ninja -->
  <svg
    viewBox="0 0 80 120"
    class="absolute left-4 bottom-10 w-16 text-paper/30"
    style="animation: ninja-sway 5.5s ease-in-out infinite;"
  >
    <!-- legs / crouch -->
    <path
      d="M20 100 Q18 80 24 70 L34 72 L36 60 L44 60 L46 72 L56 70 Q62 80 60 100 L52 104 L50 90 L44 88 L40 100 L36 88 L30 90 L28 104 Z"
      fill="currentColor"
    />
    <!-- torso -->
    <path
      d="M26 55 Q26 42 30 38 L50 38 Q54 42 54 55 L50 62 L30 62 Z"
      fill="currentColor"
    />
    <!-- arms -->
    <path
      d="M26 45 L14 55 L12 60 L20 58 L28 52 Z M54 45 L66 55 L68 60 L60 58 L52 52 Z"
      fill="currentColor"
    />
    <!-- head + mask -->
    <circle cx="40" cy="28" r="11" fill="currentColor" />
    <rect x="29" y="26" width="22" height="4" fill="#e97917" />
    <rect x="38" y="28" width="4" height="2" fill="#0f0e0c" />
    <rect x="44" y="28" width="4" height="2" fill="#0f0e0c" />
    <!-- headband tail -->
    <path
      d="M51 27 L58 22 L60 30 L52 30 Z"
      fill="#e97917"
      opacity="0.85"
    />
  </svg>

  <!-- Right side: standing ninja with kunai -->
  <svg
    viewBox="0 0 80 120"
    class="absolute right-4 top-1/3 w-16 text-paper/25"
    style="animation: ninja-sway 6.5s ease-in-out -1.5s infinite;"
  >
    <!-- legs -->
    <path
      d="M30 108 L32 70 L40 66 L48 70 L50 108 L44 110 L42 80 L38 80 L36 110 Z"
      fill="currentColor"
    />
    <!-- torso -->
    <path
      d="M28 66 Q28 48 34 42 L46 42 Q52 48 52 66 L48 70 L32 70 Z"
      fill="currentColor"
    />
    <!-- right arm raised with kunai -->
    <path d="M50 50 L64 30 L60 26 L46 48 Z" fill="currentColor" />
    <path
      d="M64 30 L70 22 L72 26 L66 34 Z"
      fill="#c9b88a"
    />
    <!-- left arm down -->
    <path d="M30 50 L22 70 L26 72 L34 52 Z" fill="currentColor" />
    <!-- head -->
    <circle cx="40" cy="32" r="10" fill="currentColor" />
    <rect x="30" y="30" width="20" height="4" fill="#e97917" />
    <!-- mask line -->
    <rect x="32" y="36" width="16" height="2" fill="#0f0e0c" opacity="0.6" />
  </svg>
</div>
