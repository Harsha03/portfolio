---
import SectionHeader from "./SectionHeader.astro";

const groups: Array<{ label: string; items: string[] }> = [
  {
    label: "Frontier Models",
    items: [
      "Claude Haiku 4.5",
      "Claude Opus",
      "GPT-4o-mini",
      "Gemini",
      "HuggingFace",
      "Whisper",
    ],
  },
  {
    label: "Agentic Patterns",
    items: [
      "Multi-agent orchestration",
      "Tool schemas (strict JSON)",
      "Structured outputs (Pydantic)",
      "Async concurrent agents",
      "Streaming outputs",
      "Confidence-thresholded review",
    ],
  },
  {
    label: "RAG & Retrieval",
    items: ["LangChain", "Chroma", "OpenAI embeddings", "Document chunking"],
  },
  {
    label: "Languages",
    items: ["Python", "TypeScript", "Swift", "JavaScript", "SQL"],
  },
  {
    label: "iOS",
    items: [
      "Swift",
      "SwiftUI",
      "SwiftData",
      "CoreLocation",
      "UserNotifications",
      "MapKit",
    ],
  },
  {
    label: "Web & Backend",
    items: [
      "Next.js 16",
      "React 19",
      "Tailwind",
      "FastAPI",
      "SSE streaming",
      "JWT",
      "SQLite",
      "Docker",
    ],
  },
  {
    label: "Tooling & Testing",
    items: ["uv", "pytest", "Vitest", "Playwright", "GitHub Actions", "Jira"],
  },
];
---

<section>
  <SectionHeader id="jutsu" label="Jutsu" plain="Skills" kanji="術" />
  <div class="mx-auto max-w-page space-y-6 px-6 pb-12">
    {
      groups.map((g) => (
        <div>
          <h3 class="mb-2 text-[11px] uppercase tracking-[0.2em] text-tan">{g.label}</h3>
          <ul class="flex flex-wrap gap-2">
            {g.items.map((s) => (
              <li class="border border-tan/30 bg-ink-2 px-3 py-1 text-sm text-paper">{s}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
