---
// Anime-style Rasengan built with real CSS 3D transforms.
// Rings are div borders rotating on different 3D axes so they genuinely
// appear to wrap around the sphere — not 2D ellipses faking depth.
// Click: scroll to top. Outer ring = scroll progress.
---

<button
  id="rasengan"
  aria-label="Scroll progress · click to return to top"
  class="group fixed bottom-6 right-6 z-50 h-[104px] w-[104px] rounded-full border border-paper/15 bg-ink/30 backdrop-blur-md transition-all duration-300 hover:scale-105 hover:border-[#7ecfff]/60 hover:bg-ink/50"
  style="perspective: 380px;"
>
  <!-- outer pulsing halo -->
  <span
    aria-hidden="true"
    class="pointer-events-none absolute inset-[-16px] rounded-full transition-all duration-300 group-hover:inset-[-24px]"
    style="background: radial-gradient(circle, rgba(126,207,255,0.55) 0%, rgba(77,163,220,0.28) 35%, transparent 70%); filter: blur(8px); animation: raseng-breathe 2.8s ease-in-out infinite;"
  ></span>

  <!-- 3D rotating rings + core, all centered in the button -->
  <span
    class="raseng-stage pointer-events-none absolute inset-0 grid place-items-center"
    style="transform-style: preserve-3d;"
  >
    <!-- sphere core (radial gradient, pulses) -->
    <span
      aria-hidden="true"
      class="raseng-core relative block h-[68px] w-[68px] rounded-full"
      style="
        background: radial-gradient(circle at 35% 30%, #ffffff 0%, #d4efff 12%, #7ecfff 28%, #2a8fd8 52%, #104681 78%, #081a33 100%);
        box-shadow:
          inset 0 0 14px rgba(255,255,255,0.35),
          inset -6px -8px 18px rgba(8,26,51,0.8),
          0 0 24px rgba(126,207,255,0.75),
          0 0 50px rgba(77,163,220,0.5);
        animation: raseng-core-pulse 2.2s ease-in-out infinite;
      "
    >
      <!-- specular highlight -->
      <span
        aria-hidden="true"
        class="absolute left-[22%] top-[16%] h-[22%] w-[30%] rounded-full"
        style="background: radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0) 70%); filter: blur(2px);"
      ></span>
    </span>

    <!-- Ring 1 — equatorial, fast -->
    <span
      aria-hidden="true"
      class="raseng-ring absolute h-[86px] w-[86px] rounded-full border-[2px] border-white/85"
      style="
        box-shadow: 0 0 10px rgba(255,255,255,0.9), inset 0 0 6px rgba(126,207,255,0.6);
        animation: raseng-ring-eq 1.2s linear infinite;
        transform-style: preserve-3d;
      "
    ></span>

    <!-- Ring 2 — meridian (vertical), slower, counter -->
    <span
      aria-hidden="true"
      class="raseng-ring absolute h-[86px] w-[86px] rounded-full border-[2px] border-[#eaf8ff]/75"
      style="
        box-shadow: 0 0 8px rgba(234,248,255,0.7);
        animation: raseng-ring-mer 1.7s linear infinite;
        transform-style: preserve-3d;
      "
    ></span>

    <!-- Ring 3 — diagonal 45°, medium -->
    <span
      aria-hidden="true"
      class="raseng-ring absolute h-[88px] w-[88px] rounded-full border-[1.5px] border-[#b6e1f9]/70"
      style="
        box-shadow: 0 0 7px rgba(182,225,249,0.8);
        animation: raseng-ring-d1 1.45s linear infinite;
        transform-style: preserve-3d;
      "
    ></span>

    <!-- Ring 4 — diagonal -45°, medium -->
    <span
      aria-hidden="true"
      class="raseng-ring absolute h-[88px] w-[88px] rounded-full border-[1.5px] border-white/65"
      style="
        box-shadow: 0 0 7px rgba(126,207,255,0.7);
        animation: raseng-ring-d2 1.55s linear infinite;
        transform-style: preserve-3d;
      "
    ></span>

    <!-- Ring 5 — outer wisp, slow -->
    <span
      aria-hidden="true"
      class="raseng-ring absolute h-[96px] w-[96px] rounded-full border border-[#7ecfff]/50"
      style="
        filter: blur(0.4px);
        animation: raseng-ring-outer 2.4s linear infinite;
        transform-style: preserve-3d;
      "
    ></span>

    <!-- hyper-fast inner core spiral (very small, very bright) -->
    <span
      aria-hidden="true"
      class="raseng-ring absolute h-[40px] w-[40px] rounded-full border-[1.5px] border-white"
      style="
        box-shadow: 0 0 8px white, inset 0 0 4px rgba(126,207,255,0.9);
        animation: raseng-ring-fast 0.6s linear infinite;
        transform-style: preserve-3d;
      "
    ></span>
  </span>

  <!-- Orbital chakra motes (in 2D plane, outside the 3D stage) -->
  <span aria-hidden="true" class="pointer-events-none absolute inset-0">
    <svg viewBox="0 0 120 120" width="104" height="104">
      <g style="transform-origin: 60px 60px; animation: raseng-spin 3s linear infinite;">
        <circle cx="60" cy="8" r="1.6" fill="#ffffff">
          <animate attributeName="opacity" values="0.1;1;0.1" dur="1.4s" repeatCount="indefinite" />
        </circle>
      </g>
      <g style="transform-origin: 60px 60px; animation: raseng-spin-rev 4.2s linear infinite;">
        <circle cx="112" cy="60" r="1.2" fill="#b6e1f9">
          <animate attributeName="opacity" values="0.1;0.9;0.1" dur="1.8s" repeatCount="indefinite" />
        </circle>
      </g>
      <g style="transform-origin: 60px 60px; animation: raseng-spin 5.4s linear infinite;">
        <circle cx="60" cy="112" r="1.4" fill="#7ecfff">
          <animate attributeName="opacity" values="0.1;0.95;0.1" dur="2.2s" repeatCount="indefinite" />
        </circle>
      </g>
    </svg>
  </span>

  <!-- Scroll progress ring (2D SVG, centered over the button) -->
  <svg viewBox="0 0 120 120" width="104" height="104" class="pointer-events-none absolute inset-0" aria-hidden="true">
    <circle cx="60" cy="60" r="58" fill="none" stroke="rgba(243, 233, 207, 0.14)" stroke-width="1.5" />
    <circle
      class="raseng-progress"
      cx="60" cy="60" r="58"
      fill="none"
      stroke="#b83227"
      stroke-width="2"
      stroke-linecap="round"
      stroke-dasharray="364.4"
      stroke-dashoffset="364.4"
      transform="rotate(-90 60 60)"
      style="transition: stroke-dashoffset 0.22s ease-out; filter: drop-shadow(0 0 4px rgba(184, 50, 39, 0.8));"
    />
  </svg>

  <span class="pointer-events-none absolute -top-9 right-0 whitespace-nowrap rounded border border-paper/20 bg-ink px-2 py-1 font-mono text-[9px] uppercase tracking-[0.25em] text-paper opacity-0 transition-opacity duration-200 group-hover:opacity-100">
    螺旋丸 · Rasengan ↑
  </span>
</button>

<script>
  const el = document.getElementById("rasengan");
  if (el) {
    const progressCircle = el.querySelector(".raseng-progress") as SVGCircleElement | null;
    const CIRC = 364.4; // 2 * π * r(58)
    const update = () => {
      const doc = document.documentElement;
      const max = doc.scrollHeight - window.innerHeight;
      const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
      if (progressCircle) {
        progressCircle.style.strokeDashoffset = String(CIRC * (1 - p));
      }
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
    el.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
  }
</script>
