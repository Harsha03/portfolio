---
// Fixed scroll-progress indicator shaped like a Rasengan orb.
// Inner spiral spins continuously; outer ring fills with scroll progress.
// Click = scroll to top.
---

<button
  id="rasengan"
  aria-label="Scroll progress · click to return to top"
  class="group fixed bottom-6 right-6 z-50 flex h-[74px] w-[74px] items-center justify-center rounded-full border border-paper/20 bg-ink/80 backdrop-blur-md transition-colors hover:border-vermillion/80"
  style="--progress: 0;"
>
  <svg viewBox="0 0 100 100" width="74" height="74" aria-hidden="true" style="filter: drop-shadow(0 0 10px rgba(80, 155, 220, 0.45));">
    <defs>
      <radialGradient id="raseng-core" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#b6e1f9" stop-opacity="0.95" />
        <stop offset="45%" stop-color="#4da3dc" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#16538a" stop-opacity="0.85" />
      </radialGradient>
      <filter id="raseng-blur" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="0.6" />
      </filter>
    </defs>

    <!-- outer progress track -->
    <circle cx="50" cy="50" r="44" fill="none" stroke="rgba(243, 233, 207, 0.15)" stroke-width="2" />
    <!-- outer progress fill (scroll-bound via --progress 0..1) -->
    <circle
      class="raseng-progress"
      cx="50"
      cy="50"
      r="44"
      fill="none"
      stroke="#b83227"
      stroke-width="2"
      stroke-linecap="round"
      stroke-dasharray="276.5"
      stroke-dashoffset="276.5"
      transform="rotate(-90 50 50)"
      style="transition: stroke-dashoffset 0.25s ease-out;"
    />

    <!-- core orb -->
    <circle cx="50" cy="50" r="32" fill="url(#raseng-core)" />

    <!-- inner spinning spiral -->
    <g style="transform-origin: 50px 50px; animation: raseng-spin 2.2s linear infinite;" filter="url(#raseng-blur)">
      <path
        d="M 50 22 A 28 28 0 0 1 78 50"
        fill="none"
        stroke="#ffffff"
        stroke-width="3"
        stroke-linecap="round"
        opacity="0.85"
      />
      <path
        d="M 50 30 A 20 20 0 0 1 70 50"
        fill="none"
        stroke="#ffffff"
        stroke-width="2.2"
        stroke-linecap="round"
        opacity="0.7"
      />
      <path
        d="M 50 38 A 12 12 0 0 1 62 50"
        fill="none"
        stroke="#ffffff"
        stroke-width="1.6"
        stroke-linecap="round"
        opacity="0.55"
      />
    </g>

    <!-- counter-rotating highlight arc -->
    <g style="transform-origin: 50px 50px; animation: raseng-spin-rev 3.6s linear infinite;">
      <path
        d="M 50 16 A 34 34 0 0 1 80 40"
        fill="none"
        stroke="rgba(255,255,255,0.6)"
        stroke-width="1.2"
        stroke-linecap="round"
      />
    </g>
  </svg>

  <!-- tooltip / label on hover -->
  <span class="pointer-events-none absolute -top-8 right-0 whitespace-nowrap rounded border border-paper/20 bg-ink px-2 py-1 font-mono text-[9px] uppercase tracking-[0.25em] text-paper opacity-0 transition-opacity group-hover:opacity-100">
    ↑ Return
  </span>
</button>

<script>
  const el = document.getElementById("rasengan");
  if (el) {
    const progressCircle = el.querySelector(".raseng-progress") as SVGCircleElement | null;
    const CIRC = 276.5; // 2 * PI * r(44)
    const update = () => {
      const doc = document.documentElement;
      const max = doc.scrollHeight - window.innerHeight;
      const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
      if (progressCircle) {
        progressCircle.style.strokeDashoffset = String(CIRC * (1 - p));
      }
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
    el.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>
