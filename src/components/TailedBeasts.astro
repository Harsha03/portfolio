---
import PixelSprite from "./PixelSprite.astro";
import { kurama, shukaku, gyuki } from "./sprites";
---

<!--
  Drifting pixel-art tailed beasts in the deep background.
  Each floats slowly across the viewport at low opacity so they don't fight the copy.
-->
<div aria-hidden="true" class="pointer-events-none fixed inset-0 z-0 overflow-hidden">
  <!-- Kurama (9-tails fox) drifts right to left, mid-height -->
  <div
    class="absolute"
    style="top: 18%; left: 100%; opacity: 0.22; animation: beast-drift-left 55s linear infinite;"
  >
    <PixelSprite
      sprite={kurama.sprite}
      palette={kurama.palette}
      pixelSize={6}
      ariaLabel="Kurama — the nine-tailed fox"
      style="filter: drop-shadow(0 0 10px rgba(233,121,23,0.35));"
    />
  </div>

  <!-- Shukaku (1-tail tanuki) drifts left to right, lower -->
  <div
    class="absolute"
    style="top: 62%; left: -20%; opacity: 0.18; animation: beast-drift-right 75s linear -22s infinite;"
  >
    <PixelSprite
      sprite={shukaku.sprite}
      palette={shukaku.palette}
      pixelSize={5}
      ariaLabel="Shukaku — the one-tailed"
      style="filter: drop-shadow(0 0 8px rgba(217,195,138,0.3));"
    />
  </div>

  <!-- Gyūki (8-tails ox-octopus) drifts right to left, upper -->
  <div
    class="absolute"
    style="top: 78%; right: 100%; opacity: 0.16; animation: beast-drift-right 90s linear -45s infinite;"
  >
    <PixelSprite
      sprite={gyuki.sprite}
      palette={gyuki.palette}
      pixelSize={4}
      ariaLabel="Gyūki — the eight-tails"
      style="filter: drop-shadow(0 0 8px rgba(74,61,126,0.4));"
    />
  </div>
</div>
