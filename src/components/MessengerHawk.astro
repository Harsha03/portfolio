---
import SectionHeader from "./SectionHeader.astro";

const links = [
  { label: "Email", href: "mailto:jaiganeshharsha@gmail.com", text: "jaiganeshharsha@gmail.com", kanji: "文" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/harsha-jaiganesh/", text: "/in/harsha-jaiganesh", kanji: "繋" },
  { label: "GitHub", href: "https://github.com/Harsha03", text: "@Harsha03", kanji: "源" },
];
---

<section class="relative bg-ink">
  <SectionHeader id="hawk" numeral="陸" label="Messenger Hawk" plain="Contact" />

  <div class="relative mx-auto max-w-page px-6 pb-20 lg:pl-24">
    <div class="grid grid-cols-12 gap-6">
      {
        links.map((l) => (
          <a
            href={l.href}
            rel="noopener"
            target={l.href.startsWith("mailto") ? "_self" : "_blank"}
            class="chakra-card group col-span-12 flex items-start gap-6 border border-paper/15 bg-ink-2 p-6 md:col-span-4 md:flex-col"
          >
            <span class="font-jp text-vermillion/80" style="font-size:3.2rem; line-height:1;">{l.kanji}</span>
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-gold/80">{l.label}</p>
              <p class="mt-2 font-display text-paper" style="font-size:1.35rem; line-height:1.15; font-variation-settings:'SOFT' 50, 'WONK' 1;">{l.text}</p>
              <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.25em] text-paper/50 brush-link">
                Send ↗
              </p>
            </div>
          </a>
        ))
      }
    </div>

    <!-- colophon -->
    <footer class="mt-16 grid grid-cols-12 gap-4 border-t border-paper/15 pt-6 font-mono text-[10px] uppercase tracking-[0.3em] text-paper/50">
      <p class="col-span-6">© {new Date().getFullYear()} · Harsha Jaiganesh</p>
      <p class="col-span-6 text-right text-gold/70">Set in Fraunces & Newsreader · 木ノ葉</p>
    </footer>
  </div>
</section>
