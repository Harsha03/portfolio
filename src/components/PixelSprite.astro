---
interface Props {
  sprite: string[];
  palette: string[];
  pixelSize?: number;
  className?: string;
  style?: string;
  ariaLabel?: string;
}
const {
  sprite,
  palette,
  pixelSize = 5,
  className = "",
  style = "",
  ariaLabel,
} = Astro.props;
const w = sprite[0].length;
const h = sprite.length;
---

<svg
  viewBox={`0 0 ${w} ${h}`}
  width={w * pixelSize}
  height={h * pixelSize}
  shape-rendering="crispEdges"
  class={className}
  style={`image-rendering: pixelated; ${style}`}
  role={ariaLabel ? "img" : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : "true"}
>
  {
    sprite.flatMap((row, y) =>
      [...row].map((ch, x) => {
        if (ch === "." || ch === " ") return null;
        const idx = parseInt(ch, 36);
        const fill = palette[idx];
        if (!fill) return null;
        return <rect x={x} y={y} width={1} height={1} fill={fill} />;
      }),
    )
  }
</svg>
