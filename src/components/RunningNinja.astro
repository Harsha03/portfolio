---
// A ninja silhouette that dashes across the bottom of the hero on load.
---

<div
  aria-hidden="true"
  class="pointer-events-none absolute bottom-4 left-0 w-full overflow-hidden"
>
  <svg
    viewBox="0 0 80 60"
    class="h-10 w-10 text-konoha/60"
    style="animation: ninja-dash 3.5s cubic-bezier(0.5, 0, 0.3, 1) 0.4s both;"
  >
    <!-- body leaning forward (running) -->
    <path
      d="M15 40 Q18 28 26 24 L44 22 Q54 22 56 30 L50 38 L38 40 Z"
      fill="currentColor"
    />
    <!-- head -->
    <circle cx="52" cy="22" r="7" fill="currentColor" />
    <rect x="46" y="20" width="14" height="3" fill="#e97917" />
    <!-- back leg -->
    <path d="M22 38 L10 52 L14 54 L26 42 Z" fill="currentColor" />
    <!-- front leg -->
    <path d="M40 38 L52 52 L48 54 L36 42 Z" fill="currentColor" />
    <!-- trailing arm -->
    <path d="M26 28 L12 22 L10 26 L26 32 Z" fill="currentColor" />
    <!-- speed lines -->
    <line x1="2" y1="25" x2="12" y2="25" stroke="#e97917" stroke-width="1.5" opacity="0.7" />
    <line x1="0" y1="32" x2="10" y2="32" stroke="#e97917" stroke-width="1.5" opacity="0.5" />
    <line x1="4" y1="39" x2="14" y2="39" stroke="#e97917" stroke-width="1.5" opacity="0.4" />
  </svg>
</div>
