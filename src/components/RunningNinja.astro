---
import PixelSprite from "./PixelSprite.astro";
import { pixelNinja } from "./sprites";
---

<div
  aria-hidden="true"
  class="pointer-events-none absolute bottom-6 left-0 w-full overflow-hidden"
>
  <div style="animation: ninja-dash 4s cubic-bezier(0.5, 0, 0.35, 1) 0.4s both;">
    <PixelSprite
      sprite={pixelNinja.sprite}
      palette={pixelNinja.palette}
      pixelSize={3}
      style="filter: drop-shadow(0 0 4px rgba(233,121,23,0.4));"
    />
  </div>
</div>
