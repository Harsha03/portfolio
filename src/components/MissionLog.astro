---
import SectionHeader from "./SectionHeader.astro";
import data from "../data/experience.json";
const entries = data.entries;
---

<section class="grain-light relative bg-paper text-ink">
  <SectionHeader id="log" numeral="参" label="Mission Log" plain="Additional Projects" variant="paper" />

  <div class="relative mx-auto max-w-page px-6 pb-24 lg:pl-24">
    <ol class="divide-y divide-ink/15">
      {
        entries.map((e, i) => (
          <li class="grid grid-cols-12 gap-6 py-10 first:pt-0">
            <div class="col-span-12 md:col-span-3">
              <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink/50">
                Entry
              </p>
              <p class="mt-1 font-display text-vermillion" style="font-size:2.25rem; line-height:1; font-weight:600;">
                .0{i + 1}
              </p>
              <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.25em] text-ink/60">{e.stack}</p>
            </div>
            <div class="col-span-12 md:col-span-9">
              <h3 class="font-display font-bold text-ink" style="font-size: clamp(1.4rem, 2.6vw, 2.1rem); line-height:1.05; font-variation-settings:'SOFT' 50, 'WONK' 1;">
                {e.title}
              </h3>
              <ul class="mt-5 space-y-3 text-[1.02rem] leading-[1.65] text-ink/85">
                {e.bullets.map((b) => (
                  <li class="relative pl-6">
                    <span class="absolute left-0 top-[0.72em] h-1.5 w-1.5 bg-vermillion"></span>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
