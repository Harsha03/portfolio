---
import SectionHeader from "./SectionHeader.astro";
import data from "../data/experience.json";
const entries = data.entries;
---

<section>
  <SectionHeader id="log" label="Mission Log" plain="Additional Projects" kanji="任務" />
  <ol class="mx-auto max-w-page px-6 pb-12">
    {
      entries.map((e) => (
        <li class="relative border-l border-tan/30 py-5 pl-6">
          <span class="absolute -left-[5px] top-7 h-2.5 w-2.5 rounded-full bg-konoha" />
          <h3 class="font-serif text-xl text-paper">{e.title}</h3>
          <p class="mt-1 text-xs uppercase tracking-wider text-tan">{e.stack}</p>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-paper/90 marker:text-konoha">
            {e.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>
